generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  updatedAt     DateTime     @updatedAt
  role          String       @default("user")
  createdAt     DateTime     @default(now())
  image         String?
  accounts      Account[]
  downloads     Download[]
  images        Image[]
  payments      Payment[]
  savedImages   SavedImage[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  images    Image[]

  @@map("category")
}

model Image {
  id          String       @id @default(uuid())
  url         String
  userId      String
  categoryId  String?
  blurhash    String?
  createdAt   DateTime     @default(now())
  width       Int?
  height      Int?
  palette     String[]
  colorTone   ColorTone    @default(NEUTRAL)
  isPremium   Boolean      @default(false)
  price       Int?
  title       String?
  description String?
  isAi        Boolean      @default(false)
  embedding   Float[]      @default([])
  downloads   Download[]
  category    Category?    @relation(fields: [categoryId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  payments    Payment[]
  savedBy     SavedImage[]

  @@map("image")
}

model SavedImage {
  id        String   @id @default(uuid())
  userId    String
  imageId   String
  type      String   @default("FAVORITE")
  createdAt DateTime @default(now())
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, imageId, type])
  @@map("saved_image")
}

/// Tracks a Khalti payment session for purchasing a premium image.
model Payment {
  id              String        @id @default(uuid())
  userId          String
  imageId         String
  pidx            String        @unique
  purchaseOrderId String        @unique
  amount          Int
  status          PaymentStatus @default(INITIATED)
  transactionId   String?
  khaltiMobile    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  download        Download?
  image           Image         @relation(fields: [imageId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment")
}

/// Represents a user's access to download a (free or purchased) image.
model Download {
  id        String   @id @default(uuid())
  userId    String
  imageId   String
  paymentId String?  @unique
  createdAt DateTime @default(now())
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  payment   Payment? @relation(fields: [paymentId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, imageId])
  @@map("download")
}

enum PaymentStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  EXPIRED
  USER_CANCELED

  @@map("payment_status")
}

enum ColorTone {
  WARM
  COOL
  NEUTRAL
  DARK
  LIGHT

  @@map("color_tone")
}
